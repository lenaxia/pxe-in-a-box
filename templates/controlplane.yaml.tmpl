version: v1alpha1
debug: false
persist: true
machine:
  type: controlplane
  token: {{ .MachineToken }}
  ca:
    crt: {{ .MachineCACert }}
    key: {{ .MachineCAKey }}
  certSANs:
    - {{ .ClusterEndpoint }}
    - 127.0.0.1
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
    extraArgs:
      rotate-server-certificates: "true"
    extraMounts:
      - destination: /var/openebs/local
        type: bind
        source: /var/openebs/local
        options:
          - bind
          - rshared
          - rw
    defaultRuntimeSeccompProfileEnabled: true
    nodeIP:
      validSubnets:
        - {{ if .NodeSubnet }}{{ .NodeSubnet }}{{ else }}192.168.0.0/16{{ end }}
    disableManifestsDirectory: true
  network:
    hostname: {{ .Hostname }}
    interfaces:
      - interface: eth0
        bond:
          deviceSelectors:
            - physical: true
        addresses:
          - {{ .NodeIP }}/16
        routes:
          - network: 0.0.0.0/0
            gateway: {{ if .Gateway }}{{ .Gateway }}{{ else }}192.168.0.1{{ end }}
        mtu: {{ if .MTU }}{{ .MTU }}{{ else }}1500{{ end }}
        dhcp: false
        vip:
          ip: {{ .ClusterEndpoint }}
    nameservers:{{ range .Nameservers }}
      - {{ . }}{{ end }}{{ if not .Nameservers }}
      - 192.168.0.2
      - 192.168.0.5
      - 192.168.0.6{{ end }}
    disableSearchDomain: true
  install:{{ if .InstallDisk }}
    disk: {{ .InstallDisk }}{{ else }}
    diskSelector:
      wwid: {{ .InstallDiskSelector }}{{ end }}
    image: {{ .InstallerImage }}
    wipe: {{ .WipeDisk }}
  files:
    - content: |-
        [plugins."io.containerd.grpc.v1.cri"]
          enable_unprivileged_ports = true
          enable_unprivileged_icmp = true
        [plugins."io.containerd.grpc.v1.cri".containerd]
          discard_unpacked_layers = false
        [plugins."io.containerd.grpc.v1.cri".containerd.runtimes.runc]
          discard_unpacked_layers = false
      permissions: 0o0
      path: /etc/cri/conf.d/20-customization.part
      op: create
  time:
    disabled: false
    servers:
      - 162.159.200.1
      - 162.159.200.123
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.rmem_max: "7500000"
    net.core.wmem_max: "7500000"
    vm.nr_hugepages: "1024"
  features:
    rbac: true
    stableHostname: true
    kubernetesTalosAPIAccess:
      enabled: true
      allowedRoles:
        - os:admin
      allowedKubernetesNamespaces:
        - system-upgrade
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true
      resolveMemberNames: true
  nodeLabels:
    node.kubernetes.io/exclude-from-external-load-balancers: ""
cluster:
  id: {{ .ClusterID }}
  secret: {{ .ClusterSecret }}
  controlPlane:
    endpoint: https://{{ .ClusterEndpoint }}:6443
  clusterName: {{ .ClusterName }}
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - {{ if .PodSubnet }}{{ .PodSubnet }}{{ else }}10.69.0.0/16{{ end }}
    serviceSubnets:
      - {{ if .ServiceSubnet }}{{ .ServiceSubnet }}{{ else }}10.96.0.0/16{{ end }}
  token: {{ .ClusterToken }}
  secretboxEncryptionSecret: {{ .SecretboxKey }}
  ca:
    crt: {{ .ClusterCACert }}
    key: {{ .ClusterCAKey }}
  aggregatorCA:
    crt: {{ .AggregatorCert }}
    key: {{ .AggregatorKey }}
  serviceAccount:
    key: {{ .ServiceAcctKey }}
  apiServer:
    image: registry.k8s.io/kube-apiserver:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
    extraArgs:
      feature-gates: AuthorizeNodeWithSelectors=false
    certSANs:
      - {{ .ClusterEndpoint }}
      - {{ .ClusterEndpoint }}
      - 127.0.0.1
    disablePodSecurityPolicy: true
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
    extraArgs:
      bind-address: 0.0.0.0
  proxy:
    disabled: true
    image: registry.k8s.io/kube-proxy:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
  scheduler:
    image: registry.k8s.io/kube-scheduler:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
    extraArgs:
      bind-address: 0.0.0.0
    config:
      apiVersion: kubescheduler.config.k8s.io/v1
      kind: KubeSchedulerConfiguration
      profiles:
        - pluginConfig:
            - args:
                defaultConstraints:
                  - maxSkew: 1
                    topologyKey: kubernetes.io/hostname
                    whenUnsatisfiable: ScheduleAnyway
                defaultingType: List
              name: PodTopologySpread
          schedulerName: default-scheduler
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: false
      service:
        disabled: true
  etcd:
    ca:
      crt: {{ .EtcdCACert }}
      key: {{ .EtcdCAKey }}
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
    advertisedSubnets:
      - {{ if .NodeSubnet }}{{ .NodeSubnet }}{{ else }}192.168.0.0/16{{ end }}
  coreDNS:
    disabled: true
  allowSchedulingOnControlPlanes: true
