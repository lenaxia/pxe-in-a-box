version: v1alpha1
debug: false
persist: true
machine:
  type: worker
  token: {{ .MachineToken }}
  ca:
    crt: {{ .MachineCACert }}
    key: ""
  certSANs:
    - {{ .ClusterEndpoint }}
    - 127.0.0.1
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ if .KubernetesVersion }}{{ .KubernetesVersion }}{{ else }}v1.35.2{{ end }}
    extraArgs:
      rotate-server-certificates: "true"
    extraMounts:
      - destination: /var/mnt/longhorn
        type: bind
        source: /var/mnt/longhorn
        options:
          - bind
          - rshared
          - rw
      - destination: /var/openebs/local
        type: bind
        source: /var/openebs/local
        options:
          - bind
          - rshared
          - rw
    defaultRuntimeSeccompProfileEnabled: true
    nodeIP:
      validSubnets:
        - {{ if .NodeSubnet }}{{ .NodeSubnet }}{{ else }}192.168.0.0/16{{ end }}
    disableManifestsDirectory: true
  network:
    hostname: {{ .Hostname }}
    interfaces:
      - interface: eth0
        bond:
          deviceSelectors:
            - physical: true
        addresses:
          - {{ .NodeIP }}/16
        routes:
          - network: 0.0.0.0/0
            gateway: {{ if .Gateway }}{{ .Gateway }}{{ else }}192.168.0.1{{ end }}
        mtu: {{ if .MTU }}{{ .MTU }}{{ else }}1500{{ end }}
        dhcp: false
    nameservers:{{ range .Nameservers }}
      - {{ . }}{{ end }}{{ if not .Nameservers }}
      - 192.168.0.2
      - 192.168.0.5
      - 192.168.0.6{{ end }}
    disableSearchDomain: true
  install:{{ if .InstallDisk }}
    disk: {{ .InstallDisk }}{{ else }}
    diskSelector:
      wwid: {{ .InstallDiskSelector }}{{ end }}
    image: {{ .InstallerImage }}
    wipe: {{ .WipeDisk }}
  files:
{{ if .IsGPU }}
    - content: |
        [plugins]
          [plugins."io.containerd.cri.v1.runtime"]
            [plugins."io.containerd.cri.v1.runtime".containerd]
              default_runtime_name = "nvidia"
      path: /etc/cri/conf.d/20-customization.part
      op: create
{{ else }}
    - content: |-
        [plugins."io.containerd.grpc.v1.cri"]
          enable_unprivileged_ports = true
          enable_unprivileged_icmp = true
        [plugins."io.containerd.grpc.v1.cri".containerd]
          discard_unpacked_layers = false
        [plugins."io.containerd.grpc.v1.cri".containerd.runtimes.runc]
          discard_unpacked_layers = false
      permissions: 0o0
      path: /etc/cri/conf.d/20-customization.part
      op: create
{{ end }}
  time:
    disabled: false
    servers:
      - 162.159.200.1
      - 162.159.200.123
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
{{ if .IsGPU }}
    net.core.bpf_jit_harden: "1"
{{ end }}
    net.core.rmem_max: "7500000"
    net.core.wmem_max: "7500000"
    vm.nr_hugepages: "1024"
  features:
    rbac: true
    stableHostname: true
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true
      resolveMemberNames: true
{{ if .IsGPU }}
  kernel:
    modules:
      - name: nvidia
      - name: nvidia_uvm
      - name: nvidia_drm
      - name: nvidia_modeset
{{ end }}
  nodeLabels:
    node-role.kubernetes.io/worker: "true"
cluster:
  id: {{ .ClusterID }}
  secret: {{ .ClusterSecret }}
  controlPlane:
    endpoint: https://{{ .ClusterEndpoint }}:6443
  clusterName: {{ .ClusterName }}
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - {{ if .PodSubnet }}{{ .PodSubnet }}{{ else }}10.69.0.0/16{{ end }}
    serviceSubnets:
      - {{ if .ServiceSubnet }}{{ .ServiceSubnet }}{{ else }}10.96.0.0/16{{ end }}
  token: {{ .ClusterToken }}
  ca:
    crt: {{ .ClusterCACert }}
    key: ""
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: false
      service:
        disabled: true
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: longhorn
provisioning:
  diskSelector:
    match: {{ if .LonghornDiskSelector }}{{ .LonghornDiskSelector }}{{ else }}disk.transport == 'nvme'{{ end }}
  grow: true
  minSize: {{ if .LonghornMinSize }}{{ .LonghornMinSize }}{{ else }}500GiB{{ end }}
