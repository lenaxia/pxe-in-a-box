{# Talos worker machine config template.
   Rendered by Ansible with Vault-decrypted secrets.

   Required variables:
     hostname              — machine hostname (e.g., worker-01)
     node_ip               — machine IP without CIDR (e.g., 192.168.3.21)

   Required Vault variables:
     machine_token         — machine join token
     machine_ca_cert       — machine CA certificate (base64 PEM)
     cluster_id            — cluster ID
     cluster_secret        — cluster secret
     cluster_name          — cluster name (e.g., home-kubernetes)
     cluster_endpoint      — control plane endpoint IP (VIP)
     cluster_token         — cluster bootstrap token
     cluster_ca_cert       — cluster CA certificate (base64 PEM)

   Optional per-machine variables:
     install_disk          — install disk path (e.g., /dev/sda)
     install_disk_selector — install disk wwid (alternative to install_disk)
     installer_image       — Talos installer image with schematic
     kubernetes_version    — kubelet image tag (default: v1.35.2)
     wipe_disk             — whether to wipe disk on install (default: false)
     nameservers           — YAML list of DNS servers
     is_gpu                — set to true for NVIDIA GPU nodes (default: false)
     longhorn_min_size     — longhorn volume min size (default: 500GiB)
     longhorn_disk_selector — longhorn disk match expression (default: nvme)
#}
version: v1alpha1
debug: false
persist: true
machine:
  type: worker
  token: {{ machine_token }}
  ca:
    crt: {{ machine_ca_cert }}
    key: ""
  certSANs:
    - {{ cluster_endpoint }}
    - 127.0.0.1
  kubelet:
    image: ghcr.io/siderolabs/kubelet:{{ kubernetes_version | default('v1.35.2') }}
    extraArgs:
      rotate-server-certificates: "true"
    extraMounts:
      - destination: /var/mnt/longhorn
        type: bind
        source: /var/mnt/longhorn
        options:
          - bind
          - rshared
          - rw
      - destination: /var/openebs/local
        type: bind
        source: /var/openebs/local
        options:
          - bind
          - rshared
          - rw
    defaultRuntimeSeccompProfileEnabled: true
    nodeIP:
      validSubnets:
        - {{ node_subnet | default('192.168.0.0/16') }}
    disableManifestsDirectory: true
  network:
    hostname: {{ hostname }}
    interfaces:
      - interface: eth0
        bond:
          deviceSelectors:
            - physical: true
        addresses:
          - {{ node_ip }}/16
        routes:
          - network: 0.0.0.0/0
            gateway: {{ gateway | default('192.168.0.1') }}
        mtu: {{ mtu | default(1500) }}
        dhcp: false
    nameservers:
{% for ns in nameservers | default(['192.168.0.2', '192.168.0.5', '192.168.0.6']) %}
      - {{ ns }}
{% endfor %}
    disableSearchDomain: true
  install:
{% if install_disk is defined and install_disk | length > 0 %}
    disk: {{ install_disk }}
{% elif install_disk_selector is defined and install_disk_selector | length > 0 %}
    diskSelector:
      wwid: {{ install_disk_selector }}
{% endif %}
    image: {{ installer_image | default('factory.talos.dev/metal-installer/0a87e2502b112e807c2dd3f91591fe372f3771188424e234a4283398297c2a33:v1.12.4') }}
    wipe: {{ wipe_disk | default(false) | lower }}
  files:
{% if is_gpu | default(false) %}
    - content: |
        [plugins]
          [plugins."io.containerd.cri.v1.runtime"]
            [plugins."io.containerd.cri.v1.runtime".containerd]
              default_runtime_name = "nvidia"
      path: /etc/cri/conf.d/20-customization.part
      op: create
{% else %}
    - content: |-
        [plugins."io.containerd.grpc.v1.cri"]
          enable_unprivileged_ports = true
          enable_unprivileged_icmp = true
        [plugins."io.containerd.grpc.v1.cri".containerd]
          discard_unpacked_layers = false
        [plugins."io.containerd.grpc.v1.cri".containerd.runtimes.runc]
          discard_unpacked_layers = false
      permissions: 0o0
      path: /etc/cri/conf.d/20-customization.part
      op: create
{% endif %}
  time:
    disabled: false
    servers:
      - 162.159.200.1
      - 162.159.200.123
  sysctls:
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
{% if is_gpu | default(false) %}
    net.core.bpf_jit_harden: "1"
{% endif %}
    net.core.rmem_max: "7500000"
    net.core.wmem_max: "7500000"
    vm.nr_hugepages: "1024"
  features:
    rbac: true
    stableHostname: true
    apidCheckExtKeyUsage: true
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true
      resolveMemberNames: true
{% if is_gpu | default(false) %}
  kernel:
    modules:
      - name: nvidia
      - name: nvidia_uvm
      - name: nvidia_drm
      - name: nvidia_modeset
{% endif %}
  nodeLabels:
    node-role.kubernetes.io/worker: "true"
cluster:
  id: {{ cluster_id }}
  secret: {{ cluster_secret }}
  controlPlane:
    endpoint: https://{{ cluster_endpoint }}:6443
  clusterName: {{ cluster_name }}
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - {{ pod_subnet | default('10.69.0.0/16') }}
    serviceSubnets:
      - {{ service_subnet | default('10.96.0.0/16') }}
  token: {{ cluster_token }}
  ca:
    crt: {{ cluster_ca_cert }}
    key: ""
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: false
      service:
        disabled: true
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: longhorn
provisioning:
  diskSelector:
    match: {{ longhorn_disk_selector | default("disk.transport == 'nvme'") }}
  grow: true
  minSize: {{ longhorn_min_size | default('500GiB') }}
